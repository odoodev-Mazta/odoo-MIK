<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="design_module.Dashboard" owl="1">

        <div class="o_dashboards container-fluid bg-light p-4 h-100 overflow-auto">

            <div class="row align-items-end bg-white p-3 rounded shadow-sm mb-4 mx-0 border">

                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-end mb-1">
                        <span class="fw-bold fs-6 text-dark">Progress Usulan</span>
                    </div>
                    <div class="progress" style="height: 22px;">
                        <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             t-attf-style="width: {{state.stats.progress_pct}}%;"
                             t-att-aria-valuenow="state.stats.progress_pct"
                             aria-valuemin="0" aria-valuemax="100">
                            <span class="fw-bold"><t t-esc="state.stats.progress_pct"/>%</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">
                        Selesai <strong class="text-dark"><t t-esc="state.stats.done"/></strong> dari <strong class="text-dark"><t t-esc="state.stats.total"/></strong> Usulan Design (<t t-esc="state.stats.progress_pct"/>%)
                    </div>
                </div>

                <div class="col-md-4 border-start">
                    <div class="d-flex justify-content-between align-items-end mb-1">
                        <span class="fw-bold fs-6 text-dark">Ontime / Overdue</span>
                    </div>
                    <div class="progress" style="height: 22px;">
                        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             t-attf-style="width: {{state.stats.ontime_pct}}%;"
                             t-att-aria-valuenow="state.stats.ontime_pct"
                             aria-valuemin="0" aria-valuemax="100">
                            <span class="fw-bold"><t t-esc="state.stats.ontime_pct"/>%</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">
                        Ontime <strong class="text-dark"><t t-esc="state.stats.ontime"/></strong> dari <strong class="text-dark"><t t-esc="state.stats.done"/></strong> yang sudah selesai (<t t-esc="state.stats.ontime_pct"/>%)
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa fa-search text-muted"/>
                        </span>
                        <input type="text"
                               class="form-control border-start-0 ps-0"
                               placeholder="Cari Brand..."
                               t-on-input="onSearchInput"/>
                    </div>
                </div>
            </div>

            <div class="bg-white p-3 rounded shadow-sm border">
                <h6 class="fw-bold text-dark mb-3"><i class="fa fa-list me-2"></i>Daftar Usulan Design</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr class="text-uppercase small text-muted">
                                <th class="border-top-0">Tgl</th>
                                <th class="border-top-0">Pelanggan</th>
                                <th class="border-top-0">Brand</th>
                                <th class="border-top-0 text-center">Status</th>
                                <th class="border-top-0 text-center">Attachment</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.designs.length === 0">
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <em>Tidak ada data desain yang ditemukan.</em>
                                    </td>
                                </tr>
                            </t>

                            <t t-foreach="state.designs" t-as="design" t-key="design.id">
                                <tr>
                                    <td><t t-esc="design.date"/></td>

                                    <td>
                                        <t t-if="design.partner_id">
                                            <t t-esc="design.partner_id[1]"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </td>

                                    <td><t t-esc="design.brand or '-'"/></td>

                                    <td class="text-center">
                                        <span t-attf-class="badge rounded-pill #{design.state === 'done' ? 'bg-success' : design.state === 'progress' ? 'bg-info' : 'bg-secondary'}">
                                            <t t-esc="design.state.charAt(0).toUpperCase() + design.state.slice(1)"/>
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <t t-if="design.attachment">
                                            <a href="#" class="text-primary text-decoration-none" title="Attachment Tersedia">
                                                <i class="fa fa-paperclip fs-5"/>
                                            </a>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted">-</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

    </t>
</templates>