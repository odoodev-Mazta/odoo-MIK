<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_account_form_inherit_header" model="ir.ui.view">
        <field name="name">account.account.form.inherit.header</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_type']" position="after">
                <field name="is_header" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>