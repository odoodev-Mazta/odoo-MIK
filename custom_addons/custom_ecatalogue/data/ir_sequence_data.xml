<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="0">
        <record id="seq_draft_mou" model="ir.sequence">
            <field name="name">Draft MOU Sequence</field>
            <field name="code">draft.mou.sequence</field>
            <field name="prefix">MIK-%(year)s/%(month)s/DM - </field>
            <field name="padding">4</field>
            <field name="use_date_range">True</field>
            <field name="suffix"></field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_mou" model="ir.sequence">
            <field name="name">MOU Sequence</field>
            <field name="code">mou.sequence</field>
            <field name="prefix">MIK-%(year)s/%(month)s/MOU - </field>
            <field name="padding">4</field>
            <field name="use_date_range">True</field>
            <field name="suffix"></field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>