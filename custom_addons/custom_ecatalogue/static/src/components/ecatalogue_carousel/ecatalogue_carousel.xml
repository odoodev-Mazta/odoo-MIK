<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_ecatalogue.EcatalogueCarouselTemplate" owl="1">
        <div class="o_ecatalogue_container p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3>E-Catalogue</h3>
                <button t-if="state.isManager" class="btn btn-primary" t-on-click="openAddProductDialog">
                    <i class="fa fa-plus me-2"/>Add Product
                </button>
            </div>

            <div class="ecatalogue-carousel d-flex flex-nowrap overflow-auto py-5 gap-4" t-ref="carouselContainer" t-on-wheel="onWheel">
                <t t-foreach="state.products" t-as="product" t-key="product.id">

                    <div class="carousel-slide card flex-shrink-0 shadow-sm"
                         style="cursor: pointer;"
                         t-att-class="{'scale-up': state.activeIndex === product_index}"
                         t-on-click="() => this.openDetail(product)">

                         <img t-if="product.image_512"
                              t-attf-src="data:image/jpeg;base64,{{product.image_512}}"
                              class="card-img-top"/>

                         <div class="card-body p-3 text-center">
                             <h4 t-esc="product.name" class="text-truncate mb-0 fw-bold"/>
                         </div>
                    </div>
                </t>
            </div>

            <div t-if="state.selectedProduct" class="ecatalogue-modal-overlay" t-on-click="closeDetail">
                <div class="ecatalogue-modal-content card shadow-lg d-flex flex-column flex-md-row" t-on-click.stop="">

                    <div class="modal-image-section bg-light d-flex align-items-center justify-content-center p-4">
                        <img t-if="state.selectedProduct.image_1920"
                             t-attf-src="data:image/jpeg;base64,{{state.selectedProduct.image_1920}}"
                             class="img-fluid object-fit-contain shadow-sm rounded"
                             style="max-height: 70vh; width: auto;"/>
                    </div>

                    <div class="modal-text-section p-4 p-md-5 position-relative d-flex flex-column" style="width: 60%; height: 100%;">
                        <button class="btn btn-close x position-absolute top-0 end-0 m-4" t-on-click="closeDetail" style="z-index: 10;"></button>

                        <h1 class="display-6 fw-bold mb-4 pe-5" t-esc="state.selectedProduct.name"/>

                        <div class="d-flex flex-row justify-content-between align-items-start gap-4 flex-grow-1 overflow-auto pr-2">

                            <div class="detail-info-left flex-grow-1">
                                <div class="mb-4">
                                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Manfaat</h5>
                                    <p class="text-muted fs-5" t-esc="state.selectedProduct.manfaat || ''" style="white-space: pre-wrap; line-height: 1.6;"/>
                                </div>

                                <div class="mb-4">
                                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Kandungan</h5>
                                    <p class="text-muted fs-5" t-esc="state.selectedProduct.kandungan || ''" style="white-space: pre-wrap; line-height: 1.6;"/>
                                </div>

                                <div class="mb-4">
                                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Spesifikasi Detail</h5>
                                    <div class="d-flex flex-column gap-2 text-muted fs-5">
                                        <div>
                                            <span class="fw-bold">Jenis Kemasan:</span>
                                            <span class="ms-1" t-esc="state.selectedProduct.jenis_kemasan"/>
                                        </div>
                                        <div>
                                            <span class="fw-bold">Berat Bersih:</span>
                                            <span class="ms-1" t-esc="state.selectedProduct.berat_bersih"/>
                                        </div>
                                        <div>
                                            <span class="fw-bold">Masa Produksi:</span>
                                            <span class="ms-1" t-esc="state.selectedProduct.masa_produksi"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="detail-info-right flex-shrink-0 sticky-top">
                                <div class="p-4 border-0 rounded-4 shadow-sm bg-white d-flex flex-column" style="min-width: 240px; border: 1px solid #eee !important;">

                                    <div class="text-center mb-3">
                                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 0.75rem;">Price (HNA)</span>
                                        <h3 class="text-primary fw-bold mb-0">Rp <t t-esc="state.selectedProduct.price ? state.selectedProduct.price.toLocaleString('id-ID') : '0'"/></h3>
                                    </div>

                                    <hr class="my-3" style="border-color: #e0e0e0;"/>

                                    <div class="d-flex flex-column gap-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted" style="font-size: 0.9rem;">
                                                Ukuran (Gr)
                                            </span>
                                            <span class="fw-bold text-dark" t-esc="state.selectedProduct.ukuran_ecatalogue"/>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted" style="font-size: 0.9rem;">
                                                <i class="fa fa-boxes me-2"></i>MOQ
                                            </span>
                                            <span class="fw-bold text-dark" t-esc="state.selectedProduct.moq_ecatalogue"/>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted" style="font-size: 0.9rem;">
                                                Total Maklon
                                            </span>
                                            <h5 class="text-bold fw-bold mb-0">
                                                Rp <t t-esc="state.selectedProduct.total_maklon ? state.selectedProduct.total_maklon.toLocaleString('id-ID') : '0'"/>
                                            </h5>
                                        </div>
                                    </div>

                                    <div class="mobile-floating-actions d-flex flex-column gap-2 mt-4 pt-2">
                                        <button class="btn btn-primary fw-bold py-2 shadow-sm rounded-3" t-on-click="createDraftMOU">
                                            <i class="fa fa-file-text-o me-2"></i>Drafting
                                        </button>

<!--                                        <button class="btn btn-outline-primary fw-bold py-2 rounded-3" t-on-click="createQuotation">-->
<!--                                            <i class="fa fa-tags me-2"></i>Quotation-->
<!--                                        </button>-->
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>