<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_ecatalogue_product_form" model="ir.ui.view">
        <field name="name">ecatalogue.product.form</field>
        <field name="model">ecatalogue.product</field>
        <field name="arch" type="xml">
            <form string="E-Catalogue Product">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="product_id" class="oe_edit_only" string="Select Master Product"/>
                        <h1><field name="product_id" placeholder="Pilih Produk Master..."/></h1>

                        <field name="name" invisible="1"/>
                    </div>
                    <group>
                        <field name="price"/>
                        <field name="ukuran_ecatalogue"/>
                        <field name="moq_ecatalogue"/>
                        <field name="total_maklon"/>
                        <field name="manfaat"/>
                        <field name="kandungan"/>
                        <field name="jenis_kemasan"/>
                        <field name="berat_bersih"/>
                        <field name="masa_produksi"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ecatalogue_product_list" model="ir.ui.view">
        <field name="name">ecatalogue.product.list</field>
        <field name="model">ecatalogue.product</field>
        <field name="arch" type="xml">
            <list string="Master E-Catalogue">
                <field name="image_512" widget="image" options="{'size': [40, 40]}" string="Foto Produk"/>
                <field name="name" string="Nama Produk"/>
                <field name="price"/>
                <field name="ukuran_ecatalogue"/>
                <field name="moq_ecatalogue"/>
                <field name="total_maklon"/>
<!--                <field name="manfaat"/>-->
<!--                <field name="kandungan"/>-->
                <field name="create_date" string="Tanggal Upload"/>
            </list>
        </field>
    </record>

    <record id="action_ecatalogue_carousel" model="ir.actions.client">
        <field name="name">E-Catalogue</field>
        <field name="tag">custom_ecatalogue.dashboard</field>
    </record>

    <record id="action_ecatalogue_master_data" model="ir.actions.act_window">
        <field name="name">Master Products</field>
        <field name="res_model">ecatalogue.product</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>