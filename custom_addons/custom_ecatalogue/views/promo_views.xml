<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_promo_form" model="ir.ui.view">
        <field name="name">view.draft.maklon.form</field>
        <field name="model">draft.maklon</field>
        <field name="arch" type="xml">
            <form string="Promo">
                <sheet>
                    <group>
                        <group>
                            <separator string="Data Pelanggan"/>
                            <field name="nama_cust"/>
                            <field name="alamat_cust"/>
                            <field name="ktp_cust"/>
                            <field name="foto_ktp_cust"/>
                            <field name="npwp_cust"/>
                            <field name="email_cust"/>
                            <field name="telp_cust"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_promo_list" model="ir.ui.view">
        <field name="name">view.draft.maklon.list</field>
        <field name="model">draft.maklon</field>
        <field name="arch" type="xml">
            <list>
                <field name="nama_cust"/>
                <field name="alamat_cust"/>
                <field name="ktp_cust"/>
<!--                <field name="foto_ktp_cust"/>-->
                <field name="npwp_cust"/>
                <field name="email_cust"/>
                <field name="telp_cust"/>
            </list>
        </field>
    </record>

    <record id="action_promo" model="ir.actions.act_window">
        <field name="name">Promo</field>
        <field name="res_model">draft.maklon</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first promo</p>
        </field>
    </record>
</odoo>