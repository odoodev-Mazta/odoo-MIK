    <!-- ====================================================================
         HALAL.REGISTRASI — ACTION
    ==================================================================== -->
    <record id="action_halal_registrasi" model="ir.actions.act_window">
        <field name="name">Registrasi Halal</field>
        <field name="res_model">halal.registrasi</field>
        <field name="view_mode">list,kanban,form</field>
        <!-- <field name="search_view_id" ref="view_halal_registrasi_search"/> -->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada registrasi halal!
            </p>
            <p>
                Buat registrasi halal baru untuk memulai proses sertifikasi.
            </p>
        </field>
    </record>

    <!-- Action: Sertifikat Hampir Kadaluarsa -->
    <record id="action_halal_hampir_kadaluarsa" model="ir.actions.act_window">
        <field name="name">Sertifikat Hampir Kadaluarsa</field>
        <field name="res_model">halal.registrasi</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('sisa_hari', '&lt;', 30), ('sisa_hari', '&gt;=', 0), ('state', '=', 'sertifikat_terbit')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tidak ada sertifikat yang hampir kadaluarsa.
            </p>
        </field>
    </record>

    <!-- Action: Sertifikat Kadaluarsa -->
    <record id="action_halal_kadaluarsa" model="ir.actions.act_window">
        <field name="name">Sertifikat Kadaluarsa</field>
        <field name="res_model">halal.registrasi</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_expired', '=', True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tidak ada sertifikat yang kadaluarsa.
            </p>
        </field>
    </record>

</odoo>