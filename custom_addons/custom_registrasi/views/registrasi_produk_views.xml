    <record id="view_registrasi_produk_search" model="ir.ui.view">
        <field name="name">registrasi.produk.search</field>
        <field name="model">registrasi.produk</field>
        <field name="arch" type="xml">
            <search string="Search Product Registrations">
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- ====================================================================
         REGISTRASI.PRODUK — ACTION
    ==================================================================== -->
    <record id="action_registrasi_produk" model="ir.actions.act_window">
        <field name="name">Product Registrations (NIE)</field>
        <field name="res_model">registrasi.produk</field>
        <field name="view_mode">list,kanban,form</field>
        <!-- <field name="search_view_id" ref="view_registrasi_produk_search"/> -->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No product registrations yet!
            </p>
            <p>
                Create a new BPOM NIE product registration to get started.
                Make sure a Brand Registration is approved first.
            </p>
        </field>
    </record>

</odoo>
