<odoo>

    <!-- ====================================================================
         REGISTRASI.PRODUK — FORM VIEW
    ==================================================================== -->
    <record id="view_registrasi_produk_form" model="ir.ui.view">
        <field name="name">registrasi.produk.form</field>
        <field name="model">registrasi.produk</field>
        <field name="arch" type="xml">
            <form string="Product Registration (NIE)">

                <!-- ── Header & Status Bar ────────────────────────────── -->
                <header>

                    <!-- DRAFT: Submit Form Request -->
                    <button
                        name="action_submit_form_request"
                        string="Submit Form Request"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />

                    <!-- FORM REQUEST: 3-tier approval buttons -->
                    <button
                        name="action_approve_marketing"
                        string="Approve (Marketing)"
                        type="object"
                        class="btn-success"
                        invisible="state != 'form_request' or approved_by_marketing != False"
                    />
                    <button
                        name="action_approve_regulatory"
                        string="Approve (Regulatory)"
                        type="object"
                        class="btn-success"
                        invisible="state != 'form_request' or not approved_by_marketing or approved_by_regulatory != False"
                    />
                    <button
                        name="action_approve_factory"
                        string="Approve (Factory Manager)"
                        type="object"
                        class="btn-success"
                        invisible="state != 'form_request' or not approved_by_regulatory or approved_by_factory != False"
                    />

                    <!-- RO DRAFTING: Confirm Official Name & Submit -->
                    <button
                        name="action_confirm_official_name_and_submit"
                        string="Confirm Name &amp; Submit to BPOM"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'ro_drafting'"
                    />

                    <!-- SUBMITTED: Request Payment (after PNBP upload) -->
                    <button
                        name="action_request_payment"
                        string="Request Payment (PNBP)"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'submitted'"
                    />

                    <!-- PAYMENT REQUEST: Finance confirms payment -->
                    <button
                        name="action_finance_approve_payment"
                        string="Confirm Payment &amp; Forward to BPOM"
                        type="object"
                        class="btn-success"
                        invisible="state != 'payment_request'"
                    />

                    <!-- BPOM REVIEW: Re-submit revised docs -->
                    <button
                        name="action_resubmit_to_bpom"
                        string="Re-Submit to BPOM"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'bpom_review'"
                    />
                    <!-- BPOM REVIEW: Revise product name (max 2) -->
                    <button
                        name="action_revise_product_name"
                        string="Revise Product Name"
                        type="object"
                        class="btn-warning"
                        invisible="state != 'bpom_review'"
                        confirm="Revising the product name will send the record back to RO Drafting. Continue?"
                    />
                    <!-- BPOM REVIEW: Issue NIE -->
                    <button
                        name="action_issue_nie"
                        string="🎉 Issue NIE"
                        type="object"
                        class="btn-success"
                        invisible="state != 'bpom_review'"
                    />

                    <!-- Reset to Draft -->
                    <button
                        name="action_reset_to_draft"
                        string="Reset to Draft"
                        type="object"
                        class="btn-secondary"
                        invisible="state in ('draft', 'nie_issued')"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,form_request,ro_drafting,submitted,payment_request,bpom_review,nie_issued"
                    />
                </header>

                <!-- ── Smart Buttons ──────────────────────────────────── -->
<!--                <div class="oe_button_box" name="button_box">-->
<!--                    <button-->
<!--                        type="object"-->
<!--                        name="action_view_produk"-->
<!--                        class="oe_stat_button"-->
<!--                        icon="fa-tag"-->
<!--                        invisible="not product_template_id"-->
<!--                    >-->
<!--                        <field name="product_template_id" widget="statinfo" string="Odoo Product"/>-->
<!--                    </button>-->
<!--                </div>-->

                <!-- ── Failed / NIE Issued Banners ────────────────────── -->
                <div class="alert alert-danger"
                     role="alert"
                     invisible="state != 'failed'">
                    <strong>❌ Registration Failed.</strong>
                    One or more products exceeded the maximum BPOM revision limit.
                </div>
                <div class="alert alert-success" role="alert"
                     invisible="state != 'nie_issued'">
                    <strong>✅ NIE Issued!</strong>
                    All product registrations have successfully received NIE numbers.
<!--                    NIE Number: <field name="nie_number" readonly="1"/>.-->
<!--                    Linked to:-->
<!--                    <field name="product_template_id" readonly="1" widget="many2one_tags"/>-->
                </div>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
<!--                        <h3 class="text-muted" invisible="not official_product_name">-->
<!--                            Official: <field name="official_product_name" readonly="1"/>-->
<!--                        </h3>-->
                    </div>

                    <!-- ── Core Information ────────────────────────────── -->
                    <group string="Registration Information">
                        <group>
                            <field name="brand_registration_id"
                                   readonly="state not in ('draft',)"/>
                            <field name="client_id"
                                   readonly="1"/>
                            <field name="category"
                                   readonly="state not in ('draft',)"/>
                        </group>
                    </group>

                    <!-- ── MoU (Import only) ───────────────────────────── -->
                    <group string="MoU Integration (Import)"
                           invisible="category != 'import'">
                        <field name="mou_id"
                               readonly="state not in ('draft',)"
                               required="category == 'import'"/>
                    </group>

                    <!-- ── Lokal Category: RnD / QC / Purchasing ─────── -->
                    <group string="Lokal Product Tracking"
                        invisible="category != 'lokal'">
                        <group string="RnD &amp; Formula">
                            <field name="rnd_formula_ref"/>
                            <field name="raw_material_status"/>
                            <field name="moq_qty"/>
                        </group>
                        <group string="QC">
                            <field name="qc_check_status"/>
                        </group>
                        <group string="Purchasing / Packaging">
                            <field name="purchasing_import_status"/>
                        </group>
                    </group>

                    <!-- ── Halal ───────────────────────────────────────── -->
                    <group string="Halal Specification">
                        <group>
                            <field name="halal_type"/>
                        </group>
                        <group>
                            <field name="halal_cert_attachment"
                                   widget="binary"
                                   filename="halal_cert_fname"/>
                            <field name="halal_cert_fname" invisible="1"/>
                        </group>
                    </group>

                    <!-- ── Design ─────────────────────────────────────── -->
                    <!-- <group string="Design &amp; Artwork">
                        <group>
                            <field name="design_id"
                                   readonly="state not in ('draft', 'ro_drafting', 'submitted')"/>
                            <field name="design_sla_type"
                                   readonly="state not in ('draft', 'ro_drafting')"/>
                        </group>
                        <group>
                            <field name="design_sla_days"/>
                        </group>
                    </group> -->

                    <!-- ── Deadlines / SLA ────────────────────────────── -->
                    <group string="SLA &amp; Deadlines"
                           invisible="state in ('draft',)">
                        <group>
                            <field name="submit_deadline" readonly="1"/>
                        </group>
                        <group>
                            <field name="bpom_review_deadline" readonly="1"
                                   invisible="state not in ('bpom_review',)"
                                   decoration-danger="bpom_review_deadline and bpom_review_deadline &lt; current_date"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ── Approval Status ────────────────────────── -->
                        <page string="Approval Status" name="approvals"
                              invisible="state == 'draft'">
                            <group string="3-Tier Approval Progress">
                                <field name="approval_state" widget="badge"
                                       decoration-success="approval_state == 'all_approved'"
                                       decoration-warning="approval_state != 'all_approved'"
                                       readonly="1"/>
                            </group>
                            <group>
                                <group string="Tier 1 — Product Marketing">
                                    <field name="approved_by_marketing" readonly="1"/>
                                    <field name="approved_date_marketing" readonly="1"/>
                                </group>
                                <group string="Tier 2 — Regulatory">
                                    <field name="approved_by_regulatory" readonly="1"/>
                                    <field name="approved_date_regulatory" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Tier 3 — Factory Manager">
                                    <field name="approved_by_factory" readonly="1"/>
                                    <field name="approved_date_factory" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Product Lines ──────────────────────────── -->
                        <page string="Product Lines" name="product_lines">
                            <field name="product_line_ids"
                                   readonly="state not in ('draft', 'form_request', 'ro_drafting')">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_template_id"/>
<!--                                    <field name="product_name"/>-->
                                    <field name="official_product_name"/>
                                    <field name="description"/>
                                    <field name="netto"/>
                                    <field name="primary_packaging"/>
                                    <field name="secondary_packaging"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── PNBP / Payment ─────────────────────────── -->
                        <page string="Payment &amp; PNBP"
                              invisible="state not in ('submitted', 'payment_request', 'payment_verification', 'bpom_review', 'nie_issued', 'failed')"
                              name="payment">
                            <group string="PNBP Document">
                                <field name="doc_pnbp"
                                       widget="binary"
                                       filename="doc_pnbp_fname"
                                       readonly="state not in ('submitted',)"/>
                                <field name="doc_pnbp_fname" invisible="1"/>
                            </group>
                            <group string="Payment Notes">
                                <field name="pnbp_notes" nolabel="1"
                                       placeholder="PNBP billing reference / notes…"
                                       readonly="state not in ('submitted', 'payment_request')"/>
                            </group>
                        </page>

                        <!-- ── BPOM Review ────────────────────────────── -->
                        <page string="BPOM Review"
                              invisible="state not in ('bpom_review', 'nie_issued', 'failed')"
                              name="bpom_review">
                            <group string="BPOM Revision Notes">
                                <field name="bpom_review_notes" nolabel="1"
                                       placeholder="BPOM requested changes / notes…"
                                       readonly="state not in ('bpom_review',)"/>
                            </group>
                            <group string="Revised Documents (Upload)">
                                <field name="doc_bpom_revision"
                                       widget="binary"
                                       filename="doc_bpom_revision_fname"
                                       readonly="state != 'bpom_review'"/>
                                <field name="doc_bpom_revision_fname" invisible="1"/>
                            </group>
                        </page>

                        <!-- ── NIE Output ─────────────────────────────── -->
                        <page string="NIE Details" name="nie" invisible="state not in ('bpom_review', 'nie_issued')">
                            <field name="product_line_ids" readonly="state != 'bpom_review'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_template_id"/>
<!--                                    <field name="product_name"/>-->
                                    <field name="official_product_name"/>
                                    <field name="product_name_revision_count"/>
                                    <field name="confirmation_counter"/>
                                    <field name="nie_number"/>
                                    <field name="nie_issued_date"/>
                                    <field name="nie_expired_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <chatter/>

            </form>
        </field>
    </record>

    <!-- ====================================================================
         REGISTRASI.PRODUK — TREE / LIST VIEW
    ==================================================================== -->
    <record id="view_registrasi_produk_tree" model="ir.ui.view">
        <field name="name">registrasi.produk.tree</field>
        <field name="model">registrasi.produk</field>
        <field name="arch" type="xml">
            <list
                decoration-success="state == 'nie_issued'"
                decoration-danger="state == 'failed'"
                decoration-warning="state in ('bpom_review', 'payment_request')"
                decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="brand_registration_id"/>
                <field name="client_id"/>
                <field name="category"/>
                <field name="mou_id"/>
                <field name="submit_deadline"/>
                <field name="bpom_review_deadline"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'nie_issued'"
                       decoration-danger="state == 'failed'"
                       decoration-warning="state in ('bpom_review', 'payment_request')"
                       decoration-info="state in ('form_request', 'ro_drafting', 'submitted', 'payment_verification')"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ====================================================================
         REGISTRASI.PRODUK — KANBAN VIEW
    ==================================================================== -->
    <record id="view_registrasi_produk_kanban" model="ir.ui.view">
        <field name="name">registrasi.produk.kanban</field>
        <field name="model">registrasi.produk</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    group_create="false">

                <field name="name"/>
                <field name="brand_registration_id"/>
                <field name="client_id"/>
                <field name="category"/>
                <field name="state"/>
                <field name="bpom_review_deadline"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>

                                <ul class="list-unstyled mt-2">
                                    <li>
                                        <strong>Brand :</strong>
                                        <field name="brand_registration_id"/>
                                    </li>

                                    <li>
                                        <strong>Client :</strong>
                                        <field name="client_id"/>
                                    </li>

                                    <li>
                                        <strong>Category :</strong>
                                        <field name="category" widget="badge"/>
                                    </li>

                                    <li t-if="record.bpom_review_deadline.raw_value">
                                        <strong>Review :</strong>
                                        <field name="bpom_review_deadline"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

