<odoo>
    <data noupdate="1">

        <!-- Sequence: registrasi.brand -->
        <record id="seq_registrasi_brand" model="ir.sequence">
            <field name="name">Brand Registration Sequence</field>
            <field name="code">registrasi.brand</field>
            <field name="prefix">REG/BRAND/%(range_year)s/</field>
            <field name="padding">4</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence: registrasi.produk -->
        <record id="seq_registrasi_produk" model="ir.sequence">
            <field name="name">Product Registration Sequence</field>
            <field name="code">registrasi.produk</field>
            <field name="prefix">REG/PROD/%(range_year)s/</field>
            <field name="padding">4</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
