<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="modul_nie.ReportingDashboardTemplate">
        <div class="o_nie_dashboard container-fluid py-4 bg-view">
            <div class="row mb-4">
                <div class="col-3">
                    <h6>Start Registrasi (<t t-esc="state.progress.start_reg"/>%)</h6>
                    <div class="progress rounded-pill" style="height: 20px;">
                        <div class="progress-bar bg-info" role="progressbar" t-attf-style="width: {{ state.progress.start_reg }}%;"/>
                    </div>
                </div>
                <div class="col-3">
                    <h6>Revisi (<t t-esc="state.progress.revisi"/>%)</h6>
                    <div class="progress rounded-pill" style="height: 20px;">
                        <div class="progress-bar bg-warning" role="progressbar" t-attf-style="width: {{ state.progress.revisi }}%;"/>
                    </div>
                </div>
                <div class="col-3">
                    <h6>Ditolak (<t t-esc="state.progress.ditolak"/>%)</h6>
                    <div class="progress rounded-pill" style="height: 20px;">
                        <div class="progress-bar bg-danger" role="progressbar" t-attf-style="width: {{ state.progress.ditolak }}%;"/>
                    </div>
                </div>
                <div class="col-3">
                    <h6>Teregist (<t t-esc="state.progress.teregist"/>%)</h6>
                    <div class="progress rounded-pill" style="height: 20px;">
                        <div class="progress-bar bg-success" role="progressbar" t-attf-style="width: {{ state.progress.teregist }}%;"/>
                    </div>
                </div>
            </div>

            <hr/>

            <div class="table-responsive bg-view p-3 rounded shadow-sm">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Tgl</th>
                            <th>Pelanggan</th>
                            <th>Brand</th>
                            <th>Status</th>
                            <th>Tgl Terbit</th>
                            <th>Masa Berakhir</th>
                            <th>Attachment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.table_data" t-as="row" t-key="row_index">
                            <tr>
                                <td><t t-esc="row.tgl"/></td>
                                <td><t t-esc="row.pelanggan"/></td>
                                <td><t t-esc="row.brand"/></td>
                                <td><t t-esc="row.status"/></td>
                                <td><t t-esc="row.tgl_terbit"/></td>
                                <td><t t-esc="row.masa_berakhir"/></td>
                                <td><t t-esc="row.attachment"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>