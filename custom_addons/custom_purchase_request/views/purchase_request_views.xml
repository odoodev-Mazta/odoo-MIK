<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_purchase_request_list" model="ir.ui.view">
        <field name="name">purchase.request.list</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <list js_class="purchase_request_list">
                <field name="date_usulan" string="Tgl Usulan"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="product_summary"/>
                <field name="total_qty" string="Qty"/>
                <field name="total_amount"
                       string="Total Harga"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="estimated_date"/>
                <field name="recommended_vendor_1" string="Vendor 1"/>
                <field name="recommended_vendor_2" string="Vendor 2"/>
                <field name="state" string="Status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <button name="action_submit" string="PR" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pr"/>
                </header>
                <sheet>
                    <widget name="web_ribbon"
                            title="URGENT"
                            bg_color="bg-danger"
                            invisible="not is_urgent"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_urgent" widget="boolean_toggle"/>
                            <field name="department_id"/>
                            <field name="pic_dept"/>
                            <field name="whatsapp_no"/>
                            <field name="estimated_date"/>
                            <field name="is_bulk_purchase"/>
                        </group>

                        <group>
                            <field name="deliver_to"/>
                            <field name="usulan_dana_id"/>
                            <field name="customer_id" invisible="is_bulk_purchase"/>
                            <field name="mou_id" options="{'no_create': True}" invisible="is_bulk_purchase"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <group>
                        <separator string="Rekomendasi Vendor"/>
                        <group string="Rekomendasi 1">
                            <field name="recommended_vendor_1"/>
                            <field name="recommended_vendor_1_address"/>
                            <field name="recommended_vendor_1_phone"/>
                            <field name="recommended_vendor_1_email"/>
                            <field name="recommended_vendor_1_website"/>
                            <field name="recommended_vendor_1_type"/>
                        </group>

                        <!-- Kolom kanan -->
                        <group string="Rekomendasi 2">
                            <field name="recommended_vendor_2"/>
                            <field name="recommended_vendor_2_address"/>
                            <field name="recommended_vendor_2_phone"/>
                            <field name="recommended_vendor_2_email"/>
                            <field name="recommended_vendor_2_website"/>
                            <field name="recommended_vendor_2_type"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="product_line_ids" widget="section_and_note_one2many" context="{'default_line_type': 'product'}">
                                <list editable="bottom">
                                    <control>
                                        <create string="Add a product"/>
                                        <create string="Add a section"
                                                context="{'default_display_type':'line_section'}"/>
                                        <create string="Add a note"
                                                context="{'default_display_type':'line_note'}"/>
                                    </control>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom"/>
                                    <field name="currency_id"/>
                                    <field name="price_unit"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="date_planned"/>
                                    <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Item Setup">
                            <field name="item_line_ids" context="{'default_line_type': 'setup'}">
                                <list editable="bottom">
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="setup_item_id"/>
                                    <field name="description"/>
                                    <field name="item_qty"/>
                                </list>
                            </field>
                        </page>
                        <page string="Alokasi Bulk"
                              invisible="not is_bulk_purchase">

                            <field name="bulk_line_ids">
                                <list editable="bottom">
                                    <field name="mou_id"/>
                                    <field name="customer_id" readonly="1"/>
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Request</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_purchase_request_list"/>
    </record>

    <!--  MENU  -->
    <menuitem
        id="menu_purchase_request"
        name="Purchase Request"
        parent="purchase.menu_procurement_management"
        action="action_purchase_request"
        sequence="1"/>

</odoo>