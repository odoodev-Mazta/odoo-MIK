<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_usulan_payment_wizard_form" model="ir.ui.view">
        <field name="name">usulan.payment.wizard.form</field>
        <field name="model">usulan.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Atur Termin Pembayaran">
                <group>
                    <group>
                        <field name="payment_type" widget="radio"/>
                        <field name="installment_count" invisible="payment_type == 'full'"/>
                        <field name="is_initialized" invisible="1"/>
                    </group>
                    <group>
                        <field name="total_amount"/>
                    </group>
                </group>

                <field name="wizard_line_ids">
                    <list editable="bottom" create="0" delete="0">
                        <field name="date_payment"/>
                        <field name="amount_percentage" sum="Total %"/>
                        <field name="amount" sum="Total"/>
                    </list>
                </field>

                <footer>
                    <button string="Confirm" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>