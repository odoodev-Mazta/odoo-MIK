<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_calendar_plan_payment_popup" model="ir.ui.view">
        <field name="name">calendar.plan.payment.popup.form</field>
        <field name="model">usulan.plan.payment.calendar.wizard</field>
        <field name="arch" type="xml">
            <form string="Plan Payment">
                <sheet>
                    <group>
                        <field name="selected_date" readonly="1"/>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="department_id"/>
                            <field name="tgl_usulan"/>
                            <field name="due_date"/>
                            <field name="description"/>
                            <field name="amount"/>
                            <field name="state" widget="badge"/>
                            <field name="plan_payment_id"/>
                            <button name="action_open_plan_payment"
                                    type="object"
                                    string="Open"
                                    class="btn-primary"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>