<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_calendar_plan_payment_popup" model="ir.ui.view">
        <field name="name">calendar.plan.payment.popup.form</field>
        <field name="model">usulan.plan.payment.calendar.wizard</field>
        <field name="arch" type="xml">
            <form string="Plan Payment Dashboard">
                <sheet>
                    <group col="2">
                        <!-- LEFT SIDE -->
                        <group string="Department Summary">

                            <!-- nanti diisi qweb/html -->
                            <field name="department_summary_html"
                                   widget="html"
                                   readonly="1"/>
                        </group>

                        <!-- RIGHT SIDE -->
                        <group string="Plan Payment List">
                            <field name="schedule_ids" options="{'no_delete': True, 'no_create': True}">
                                <list editable="bottom">
                                    <field name="department_id"/>
                                    <field name="date_payment"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="plan_payment_date"/>
                                    <button name="action_open_plan_payment"
                                            type="object"
                                            icon="fa-external-link"
                                            title="Open Plan Payment"/>
                                </list>
                            </field>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Save Changes"
                            name="action_save_changes"
                            type="object"
                            class="btn-primary"/>

                    <button string="Close"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>