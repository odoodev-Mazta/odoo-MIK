<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_usulan_mass_payment_wizard_form" model="ir.ui.view">
        <field name="name">usulan.mass.payment.wizard.form</field>
        <field name="model">usulan.mass.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Gabung Tagihan">
                <group>
                    <field name="payment_date"/>
                </group>
                <footer>
                    <button name="action_create_merged_bill" string="Buat Tagihan Gabungan" type="object" class="btn-primary"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_usulan_mass_payment_wizard" model="ir.actions.act_window">
        <field name="name">Gabung Plan Payment</field>
        <field name="res_model">usulan.mass.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> <field name="binding_model_id" ref="model_usulan_plan_payment"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>