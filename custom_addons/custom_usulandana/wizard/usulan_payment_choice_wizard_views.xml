<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_usulan_payment_choice_wizard_form" model="ir.ui.view">
        <field name="name">usulan.payment.choice.wizard.form</field>
        <field name="model">usulan.payment.choice.wizard</field>
        <field name="arch" type="xml">
            <form string="Pilih Metode Pembayaran">
                <group>
                    <p class="text-muted">
                        Silakan pilih metode pelunasan untuk Usulan Dana ini.
                    </p>
                    <field name="payment_choice" widget="radio" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Lanjut" type="object" class="btn-primary oe_highlight"/>
                    <button string="Batal" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>