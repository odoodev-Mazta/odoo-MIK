<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_uang_lainnya_wizard_form" model="ir.ui.view">
        <field name="name">uang.lainnya.wizard.form</field>
        <field name="model">uang.lainnya.wizard</field>
        <field name="arch" type="xml">
            <form string="Uang Lainnya">
                <sheet>

                    <group>
                        <field name="total" readonly="1"/>
                    </group>

                    <group>
                        <field name="line_ids">
                            <list editable="bottom" create="true" delete="true">
                                <field name="tanggal"/>
                                <field name="jenis_id"/>
                                <field name="dari"/>
                                <field name="ke"/>
                                <field name="amount"/>
                                <field name="keterangan"/>
                            </list>
                        </field>
                    </group>

                    <footer>
                        <button name="action_confirm"
                                type="object"
                                string="Simpan"
                                class="btn-primary"/>

                        <button string="Batal"
                                special="cancel"/>
                    </footer>

                </sheet>
            </form>
        </field>
    </record>

</odoo>