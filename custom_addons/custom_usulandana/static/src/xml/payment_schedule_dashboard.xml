<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="custom_usulandana.PaymentScheduleDashboard">
        <div class="schedule_dashboard">
            <!-- LEFT SIDE -->
            <div class="schedule_left">
                <!-- HEADER -->
                <div class="dashboard_header">
                    <select t-model="state.year">
                        <option value="2025">2025</option>
                        <option value="2026">2026</option>
                    </select>

                    <div class="summary waiting">
                        Menggantung:
                        <t t-esc="state.data.summary?.menggantung"/>
                    </div>

                    <div class="summary plan">
                        Plan Payment:
                        <t t-esc="state.data.summary?.plan_payment"/>
                    </div>

                    <div class="summary reschedule">
                        Reschedule:
                        <t t-esc="state.data.summary?.reschedule"/>
                    </div>
                </div>

                <!-- MONTH -->
                <div class="month_selector">
                    <t t-foreach="months"
                       t-as="month"
                       t-key="month.number">

                        <button
                            t-att-class="state.month === month.number ? 'active_month' : ''"
                            t-on-click="() => this.selectMonth(month.number)">

                            <t t-esc="month.name"/>
                        </button>
                    </t>
                </div>

                <!-- DAY HEADER -->
                <div class="calendar_header">
                    <div>Sen</div>
                    <div>Sel</div>
                    <div>Rab</div>
                    <div>Kam</div>
                    <div>Jum</div>
                    <div>Sab</div>
                    <div>Min</div>
                </div>
                <!-- CALENDAR BODY -->
                <div class="calendar_body">

                    <t t-foreach="state.data.calendar || []"
                       t-as="week"
                       t-foreach-index="week_index"
                       t-key="week_index">

                        <div class="calendar_week">

                            <t t-foreach="week"
                               t-as="day"
                               t-foreach-index="day_index"
                               t-key="day_index">

                                <div t-att-class="
                                        'calendar_day ' +
                                        (day.is_holiday ? 'holiday ' : '') +
                                        (day.is_sunday ? 'sunday ' : '') +
                                        (!day.day ? 'empty_day' : '')
                                    "
                                    t-on-click="() => this.openSchedulePopup(day.full_date)"
                                >

                                    <div class="day_number">
                                        <t t-esc="day.day"/>
                                    </div>

                                    <t t-if="day.holiday_name">
                                        <div class="holiday_label">
                                            <t t-esc="day.holiday_name"/>
                                        </div>
                                    </t>

                                    <t t-if="day.payments_count">
                                        <div class="payment_summary">
                                            <div class="payment_count">
                                                <t t-esc="day.payments_count"/>
                                                Plan Payment
                                            </div>

                                            <div class="payment_amount">
                                                Rp
                                                <t t-esc="day.payments_total"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <div class="schedule_right">
                <!-- BIG CONTAINER -->
                <div class="right_card big_right_card">

                    <!-- TITLE -->
                    <div class="big_right_title">
                        Dashboard Simulasi Payment
                    </div>

                    <!-- SIMULASI -->
                    <div class="inner_card">

                        <div class="right_title">
                            Simulasi Payment
                            <t t-esc="months.find(m => m.number === state.month)?.name"/>
                            <t t-esc="state.year"/>
                        </div>

                        <div class="week_summary">

                            <t t-foreach="state.data.week_summary || []"
                               t-as="week"
                               t-key="week.week">

                                <div class="week_item">

                                    <div class="week_name">
                                        Minggu <t t-esc="week.week"/>
                                    </div>

                                    <div class="week_amount">
                                        Rp <t t-esc="week.total"/>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- FINANCIAL -->
                    <div class="inner_card">
                        <div class="section_block">

                            <div class="right_title">
                                Plan Payment
                            </div>

                            <div class="finance_section">
                                <t t-foreach="state.data.weekly_plan_payment || []"
                                   t-as="week"
                                   t-key="week.week">

                                    <div class="finance_item">
                                        <span>
                                            Minggu <t t-esc="week.week"/>
                                        </span>

                                        <strong>
                                            Rp <t t-esc="week.amount"/>
                                        </strong>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="section_block section_spacing">
                            <div class="right_title">
                                Rincian Dana
                            </div>

                            <div class="finance_section">
                                <div class="finance_item">
                                    <span>Saldo Bank</span>

                                    <strong>
                                        Rp <t t-esc="state.data.bank_balance || 0"/>
                                    </strong>
                                </div>

                                <div class="finance_item">
                                    <span>Outstanding Piutang</span>

                                    <strong>
                                        Rp <t t-esc="state.data.outstanding_receivable || 0"/>
                                    </strong>
                                </div>

                                <div t-att-class="'finance_item surplus_item ' + (state.data.surplus_negative ? 'negative_surplus' : '')">
                                    <span>Surplus</span>

                                    <strong>
                                        Rp <t t-esc="state.data.surplus || 0"/>
                                    </strong>

                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- UPDATE -->
                    <div class="inner_card">
                        <div class="right_title">
                            Update Plan Payment Hari Ini
                        </div>

                        <div class="update_item released">
                            <div class="update_header">
                                <div class="update_label">
                                    Rilis
                                </div>

                                <div class="update_percent">
                                    <t t-esc="state.data.release_percentage || 0"/>%
                                </div>
                            </div>

                            <div class="progress_bar">
                                <div class="progress_fill released_fill"
                                     t-att-style="'width:' + (state.data.release_percentage || 0) + '%'">
                                </div>
                            </div>

                            <div class="update_amount">
                                Rp <t t-esc="state.data.today_release_amount || 0"/>
                            </div>
                        </div>

                        <div class="update_item pending">
                            <div class="update_header">
                                <div class="update_label">
                                    Not Yet
                                </div>

                                <div class="update_percent">
                                    <t t-esc="state.data.pending_percentage || 0"/>%
                                </div>
                            </div>

                            <div class="progress_bar">
                                <div class="progress_fill pending_fill"
                                     t-att-style="'width:' + (state.data.pending_percentage || 0) + '%'">
                                </div>
                            </div>

                            <div class="update_amount">
                                Rp <t t-esc="state.data.today_pending_amount || 0"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>