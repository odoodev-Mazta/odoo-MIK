<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_usulan_usulan_dana" model="ir.sequence">
            <field name="name">Sequence Usulan Dana</field>
            <field name="code">usulan.usulan.dana</field>
            <field name="prefix">MIK-%(year)s/%(month)s/UD-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_usulan_up_country" model="ir.sequence">
            <field name="name">Sequence Up Country</field>
            <field name="code">usulan.up.country</field>
            <field name="prefix">MIK-%(year)s/%(month)s/UC-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>