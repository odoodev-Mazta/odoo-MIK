<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_usulan_dana" model="ir.module.category">
        <field name="name">Usulan Dana</field>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_usulan_dana_access" model="res.groups.privilege">
        <field name="name">Usulan Dana Access</field>
        <field name="category_id" ref="module_category_usulan_dana"/>
    </record>

    <record id="group_head_dept" model="res.groups">
        <field name="name">Head Dept</field>
        <field name="privilege_id" ref="privilege_usulan_dana_access"/>
    </record>

    <record id="group_coo" model="res.groups">
        <field name="name">COO</field>
        <field name="privilege_id" ref="privilege_usulan_dana_access"/>
    </record>

    <record id="group_ceo" model="res.groups">
        <field name="name">CEO</field>
        <field name="privilege_id" ref="privilege_usulan_dana_access"/>
    </record>

    <record id="group_finance" model="res.groups">
        <field name="name">Finance</field>
        <field name="privilege_id" ref="privilege_usulan_dana_access"/>
    </record>

    <record id="rule_usulan_dana_head_dept" model="ir.rule">
        <field name="name">Head Dept: Hanya Departemen Sendiri</field>
        <field name="model_id" ref="model_usulan_usulan_dana"/>
        <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_head_dept'))]"/>
    </record>

    <record id="rule_usulan_dana_coo" model="ir.rule">
        <field name="name">COO: Semua Dept (Hanya Nominal COO)</field>
        <field name="model_id" ref="model_usulan_usulan_dana"/>
        <field name="domain_force">[('req_coo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_coo'))]"/>
    </record>

    <record id="rule_usulan_dana_ceo" model="ir.rule">
        <field name="name">CEO: Semua Dept (Hanya Nominal CEO)</field>
        <field name="model_id" ref="model_usulan_usulan_dana"/>
        <field name="domain_force">[('req_ceo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_ceo'))]"/>
    </record>

    <record id="rule_usulan_dana_finance" model="ir.rule">
        <field name="name">Finance: Global Access (Semua Data)</field>
        <field name="model_id" ref="model_usulan_usulan_dana"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_finance'))]"/>
    </record>

    <record id="rule_plan_payment_head_dept" model="ir.rule">
        <field name="name">Plan Payment: Head Dept (Own Dept)</field>
        <field name="model_id" ref="model_usulan_plan_payment"/>
        <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_head_dept'))]"/>
    </record>

    <record id="rule_plan_payment_ceo" model="ir.rule">
        <field name="name">Plan Payment: CEO (Nominal Only)</field>
        <field name="model_id" ref="model_usulan_plan_payment"/>
        <field name="domain_force">[('usulan_dana_id.req_ceo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_ceo'))]"/>
    </record>

    <record id="rule_plan_payment_coo" model="ir.rule">
        <field name="name">Plan Payment: COO (Nominal Only)</field>
        <field name="model_id" ref="model_usulan_plan_payment"/>
        <field name="domain_force">[('usulan_dana_id.req_coo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_coo'))]"/>
    </record>

    <record id="rule_plan_payment_finance" model="ir.rule">
        <field name="name">Plan Payment: Finance Global Access</field>
        <field name="model_id" ref="model_usulan_plan_payment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_finance'))]"/>
    </record>

    <record id="rule_approval_head_dept" model="ir.rule">
        <field name="name">Approval Usulan: Head Dept</field>
        <field name="model_id" ref="model_usulan_dana_approval"/>
        <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_head_dept'))]"/>
    </record>

    <record id="rule_approval_coo" model="ir.rule">
        <field name="name">Approval Dashboard: COO (Nominal Only)</field>
        <field name="model_id" ref="model_usulan_dana_approval"/>
        <field name="domain_force">[('req_coo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_coo'))]"/>
    </record>

    <record id="rule_approval_ceo" model="ir.rule">
        <field name="name">Approval Dashboard: CEO (Nominal Only)</field>
        <field name="model_id" ref="model_usulan_dana_approval"/>
        <field name="domain_force">[('req_ceo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_ceo'))]"/>
    </record>

    <record id="rule_approval_finance" model="ir.rule">
        <field name="name">Approval Dashboard: Finance (Full Access)</field>
        <field name="model_id" ref="model_usulan_dana_approval"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_finance'))]"/>
    </record>

</odoo>