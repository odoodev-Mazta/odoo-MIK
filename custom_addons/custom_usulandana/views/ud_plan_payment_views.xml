<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_usulan_plan_payment" model="ir.actions.act_window">
        <field name="name">Plan Payment</field>
        <field name="res_model">usulan.plan.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_plan_payment_list" model="ir.ui.view">
        <field name="name">usulan.plan.payment.list</field>
        <field name="model">usulan.plan.payment</field>
        <field name="arch" type="xml">
            <list js_class="plan_payment_dashboard_list" create="0" delete="0">
                <field name="name" string="No. Plan"/>
                <field name="usulan_dana_id" string="Sumber Usulan"/>
                <field name="department_id"/>

                <field name="amount_total" widget="monetary" sum="Total Keseluruhan"/>

                <field name="payment_progress" string="Progres Bayar"/>

                <field name="state" widget="badge"
                       decoration-muted="state == 'menggantung'"
                       decoration-info="state == 'plan_payment'"
                       decoration-warning="state == 'reschedule'"
                       decoration-success="state == 'rilis'"
                       decoration-danger="state == 'cancel'"/>

                <button name="action_view_payment_schedules" type="object"
                    string="Jadwal" icon="fa-calendar" class="btn-secondary"
                    invisible="state in ('cancel', 'rilis')"/>
            </list>
        </field>
    </record>

    <record id="view_plan_payment_form" model="ir.ui.view">
        <field name="name">usulan.plan.payment.form</field>
        <field name="model">usulan.plan.payment</field>
        <field name="arch" type="xml">
            <form string="Plan Payment">
                <header>
                    <button name="action_confirm_plan" string="Set Plan" type="object" class="oe_highlight" invisible="state != 'menggantung'"/>
                    <button name="action_reschedule" string="Reschedule" type="object" invisible="state not in ('plan_payment', 'menggantung')"/>
                    <field name="state" widget="statusbar" statusbar_visible="menggantung,plan_payment,reschedule,rilis,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="usulan_dana_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="mou_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Jadwal Pembayaran" name="payment_lines">
                            <field name="payment_line_ids">
                                <list editable="bottom" create="0">
                                    <field name="date_payment" string="Tanggal Termin (Deadline)"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="plan_payment_date" string="Rencana Bayar"/>
                                    <field name="actual_payment_date" string="Tgl Pembayaran (Aktual)" readonly="1"/>
                                    <field name="state" widget="badge" decoration-success="state == 'paid'"/>
                                    <button name="action_pay_termin" type="object" string="Pilih Cara Bayar"
                                            icon="fa-file-text-o" class="btn-info" invisible="not vendor_bill_id"/>

                                    <field name="vendor_bill_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_plan_payment_quick_date_form" model="ir.ui.view">
        <field name="name">usulan.plan.payment.quick.date.form</field>
        <field name="model">usulan.plan.payment</field>
        <field name="arch" type="xml">
            <form string="Set Plan Payment">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="department_id" readonly="1"/>
                    </group>

                    <field name="payment_line_ids">
                        <list editable="bottom">
                            <field name="date_payment" readonly="1"/>
                            <field name="amount" readonly="1"/>
                            <field name="plan_payment_date"/>
                            <field name="state" readonly="1"/>
                        </list>
                    </field>
                </sheet>

                <footer>
                    <button string="Save"
                            special="save"
                            class="btn-primary"/>

                    <button string="Close"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>