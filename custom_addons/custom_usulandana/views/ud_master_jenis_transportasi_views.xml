<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_master_jenis_transportasi_list" model="ir.ui.view">
        <field name="name">jenis.transportasi.list</field>
        <field name="model">jenis.transportasi</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_master_jenis_transportasi_form" model="ir.ui.view">
        <field name="name">jenis.transportasi.form</field>
        <field name="model">jenis.transportasi</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_master_jenis_transportasi" model="ir.actions.act_window">
        <field name="name">Jenis Transportasi</field>
        <field name="res_model">jenis.transportasi</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>