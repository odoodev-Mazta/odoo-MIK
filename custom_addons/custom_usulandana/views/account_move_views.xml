<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_move_form_inherit_usulan" model="ir.ui.view">
        <field name="name">account.move.form.inherit.usulan</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!--     Tambah field UD di bawah reference       -->
            <xpath expr="//field[@name='ref']" position="after">
                <field name="usulan_dana_id"
                       invisible="move_type != 'entry'"
                       options="{'no_create': True}"
                       placeholder="Pilih Usulan Dana pencairan..."/>
            </xpath>
        </field>
    </record>
</odoo>