<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_usulan_usulan_dana" model="ir.actions.act_window">
        <field name="name">Usulan Dana</field>
        <field name="res_model">usulan.usulan.dana</field>
        <field name="view_mode">list,form</field>
        <field name="context">
            {'default_document_type': 'ud'}
        </field>
    </record>

    <record id="view_usulan_usulan_dana_list" model="ir.ui.view">
        <field name="name">usulan.usulan.dana.list</field>
        <field name="model">usulan.usulan.dana</field>
        <field name="arch" type="xml">
            <list js_class="usulan_usulan_dana_list">
                <field name="name"/>
                <field name="department_id"/>
                <field name="tgl_usulan"/>
<!--                <field name="date_created"/>-->
                <field name="jenis" widget="badge" decoration-info="jenis == 'draft'"/>
                <field name="description" string="Ket"/>
                <field name="amount_total" sum="Total"/>
                <field name="date_submitted"/>
                <field name="status_approval" widget="badge" decoration-warning="status_approval == 'waiting'" decoration-success="status_approval == 'approved'"/>
                <field name="status_plan_payment" widget="badge"/>
                <field name="status_payment" widget="badge" decoration-success="status_payment == 'paid'"/>
                <field name="state" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_usulan_usulan_dana_form" model="ir.ui.view">
        <field name="name">usulan.usulan.dana.form</field>
        <field name="model">usulan.usulan.dana</field>
        <field name="arch" type="xml">
            <form string="Usulan Dana">
                <header>
                    <button name="action_submit" string="Ajukan" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_set_to_draft" string="Set to Draft" type="object"
                            class="btn-secondary" invisible="state not in ('waiting_head', 'waiting_coo', 'waiting_ceo', 'waiting_finance', 'approve', 'check_tax', 'plan_payment', 'reject', 'cancel')"/>
                    <button name="action_approve_head" string="Approve (Head Dept)" type="object" class="btn-success oe_highlight"
                            invisible="state != 'waiting_head'"
                            groups="custom_usulandana.group_head_dept"/>
                    <button name="action_approve_coo" string="Approve (COO)" type="object" class="btn-success oe_highlight"
                            invisible="state != 'waiting_coo'"
                            groups="custom_usulandana.group_coo"/>
                    <button name="action_approve_ceo" string="Approve (CEO)" type="object" class="btn-success oe_highlight"
                            invisible="state != 'waiting_ceo'"
                            groups="custom_usulandana.group_ceo"/>
                    <button name="action_approve_finance" string="Approve" type="object" class="btn-primary oe_highlight"
                            invisible="state != 'waiting_finance'"
                            groups="custom_usulandana.group_finance"/>
                    <button name="action_request_tax" string="Cek Tax" type="object"
                            invisible="state != 'approve'" class="btn-primary"/>
                    <button name="action_create_plan_payment" string="Buat Plan Payment" type="object"
                            invisible="state != 'plan_payment' or plan_payment_id" class="btn-primary"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger"
                            invisible="state not in ('waiting_head', 'waiting_coo', 'waiting_ceo', 'waiting_finance')"/>
                    <button name="action_cancel" type="object" string="Cancel Usulan"
                            class="btn-danger"
                            invisible="state == 'cancel'"
                            groups="custom_usulandana.group_head_dept"
                            confirm="Apakah Anda yakin ingin membatalkan Usulan Dana ini? Tindakan ini akan membatalkan Plan Payment yang terkait."/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_head,waiting_finance,approve,check_tax,plan_payment,rilis"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Data Departemen">
                            <field name="is_advance" widget="boolean_toggle"/>
                            <field name="department_id"/>
                            <field name="pic_id"/>
                            <field name="pic_phone" widget="phone"/>
                            <field name="pic_bank_account"/>
                            <field name="tgl_usulan"/>
                        </group>

                        <group string="Data Vendor">
                            <field name="purchase_order_id" options="{'no_create': True}" placeholder="Pilih No. PO jika ada..."/>
                            <field name="vendor_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'supplier'}"/>
                            <field name="vendor_address"/>
                            <field name="vendor_phone" widget="phone"/>
                            <field name="payment_method"/>
                            <field name="vendor_bank_account" invisible="payment_method != 'transfer'"/>
                        </group>

                        <group string="Dokumen Pendukung">
                            <field name="attachment_ids" widget="many2many_binary" string="Lampiran"/>
                        </group>

                        <group string="Mode Termin Pembayaran">
                            <field name="payment_mode" widget="radio"
                                   readonly="state != 'draft'"/>

                            <!-- Tombol + ringkasan termin — hanya muncul jika per_usulan -->
                            <field name="header_payment_summary"
                                   string="Info Termin"
                                   readonly="1"
                                   invisible="payment_mode != 'per_usulan'"/>
                            <button name="action_open_header_payment_wizard"
                                    type="object"
                                    string="⚙ Atur Termin Pembayaran"
                                    class="btn-primary"
                                    invisible="payment_mode != 'per_usulan' or state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Jadwal Pembayaran"
                              name="header_schedule"
                              invisible="payment_mode != 'per_usulan'">
                            <field name="header_schedule_ids"
                                   readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="date_payment"/>
                                    <field name="amount_percentage"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>

                        <page string="Item Details" name="item_details">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
<!--                                    <field name="item_name"/>-->
                                    <field name="product_id"/>
                                    <field name="setup_item_id"/>
                                    <field name="account_id" options="{'no_open': True}"/>
                                    <field name="keterangan"/>
                                    <field name="mou_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="price_unit"/>
                                    <field name="currency_id"/>
                                    <field name="is_foreign_currency" column_invisible="1"/>
                                    <field name="idr_currency_id" column_invisible="1"/>
                                    <field name="today_rate"/>
                                    <field name="discount"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="pph_id" readonly="1"/>
                                    <field name="price_subtotal" readonly="1" force_save="1"/>
                                    <field name="grand_total" readonly="1" force_save="1"/>
                                    <field name="grand_total_currency" readonly="1" force_save="1"/>
                                    <field name="payment_summary" readonly="1" force_save="1"/>
                                    <button name="action_open_payment_wizard" type="object" string="Set Termin" icon="fa-calendar" class="btn-secondary"/>
                                    <field name="ppn_amount" column_invisible="1"/>
                                </list>
                            </field>

                            <group class="oe_subtotal_footer oe_right" colspan="2" name="usulan_total">
                                <field name="is_ppn" widget="boolean_toggle" string="PPN(11%)"/>
                                <field name="amount_invoice_raw" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_discount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_dpp" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_ppn" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <label for="amount_total"/>
                                </div>
                                <field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>

                            <div class="clearfix"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <chatter />
                </div>
            </form>
        </field>
    </record>

    <record id="view_usulan_dana_search" model="ir.ui.view">
        <field name="name">usulan.usulan.dana.search</field>
        <field name="model">usulan.usulan.dana</field>
        <field name="arch" type="xml">
            <search string="Cari Usulan">
                <field name="name" string="No. Usulan"/>
                <field name="department_id" readonly="1" force_save="1"/>

                <filter string="Menunggu Persetujuan Saya" name="my_approval"
                        domain="[('is_my_approval', '=', True)]"/>

                <separator/>

                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approve')]"/>
            </search>
        </field>
    </record>

    <record id="action_usulan_dana_to_approve" model="ir.actions.act_window">
        <field name="name">Menunggu Persetujuan</field>
        <field name="res_model">usulan.usulan.dana</field>
        <field name="view_mode">list,form</field>

        <field name="context">{'search_default_my_approval': 1}</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Semua beres! Tidak ada usulan yang menunggu persetujuan Anda.
            </p>
        </field>
    </record>

</odoo>