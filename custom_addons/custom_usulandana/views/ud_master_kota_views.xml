<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_usulan_master_kota_list" model="ir.ui.view">
        <field name="name">usulan.master.kota.list</field>
        <field name="model">usulan.master.kota</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_usulan_master_kota_form" model="ir.ui.view">
        <field name="name">usulan.master.kota.form</field>
        <field name="model">usulan.master.kota</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_usulan_master_kota" model="ir.actions.act_window">
        <field name="name">Master Kota</field>
        <field name="res_model">usulan.master.kota</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>