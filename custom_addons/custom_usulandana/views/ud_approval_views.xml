    <record id="view_approval_ud_list" model="ir.ui.view">
        <field name="name">usulan.dana.approval.list</field>
        <field name="model">usulan.dana.approval</field>
        <field name="arch" type="xml">
            <list js_class="approval_dashboard_list" create="0" edit="0" delete="0">
                <field name="date_requested"/>
                <field name="source_model" string="Tipe" widget="badge" decoration-info="source_model == 'usulan.dana'" decoration-warning="source_model == 'usulan.up.country'"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="description"/>
                <field name="amount" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'to_approve'"
                       decoration-success="state == 'approve'"
                       decoration-danger="state == 'reject'"/>

                <button name="action_buka_dokumen" type="object" string="Buka Detail" class="btn btn-sm btn-primary"/>
            </list>
        </field>
    </record>

</odoo>