<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_usulan_dana_tax" model="ir.actions.act_window">
        <field name="name">Cek Tax UD</field>
        <field name="res_model">usulan.dana.tax</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_usulan_dana_tax_list" model="ir.ui.view">
        <field name="name">usulan.dana.tax.list</field>
        <field name="model">usulan.dana.tax</field>
        <field name="arch" type="xml">
            <list>
                <field name="usulan_dana_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_usulan_dana_tax_form" model="ir.ui.view">
        <field name="name">usulan.dana.tax.form</field>
        <field name="model">usulan.dana.tax</field>
        <field name="arch" type="xml">
            <form string="Cek Tax Usulan Dana">
                <header>
                    <button name="action_validate"
                            type="object"
                            string="Validate Tax"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="usulan_dana_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Item Details">
                            <field name="line_ids">
                                <list editable="bottom">
<!--                                    <field name="usulan_line_id" readonly="1"/>-->
                                    <field name="description" readonly="1"/>
                                    <field name="original_amount" readonly="1"/>
                                    <field name="pph_id"/>
                                    <field name="tax_amount"/>
                                    <field name="final_amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>