<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="custom_mou.MainTemplate" owl="1">
        <div class="o_dashboard_container p-4 bg-light w-100 h-100 overflow-auto">
            <h2 class="mb-4 text-black fw-bold">Memorandum Of Understanding Dashboard</h2>

            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body" style="height: 300px;">
                            <canvas t-ref="chart1"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body" style="height: 300px;">
                            <canvas t-ref="chart2"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body" style="height: 300px;">
                            <canvas t-ref="chart3"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body" style="height: 300px;">
                            <canvas t-ref="chart4"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                <h6 class="text-muted mb-0">
                    Menampilkan: <span class="badge bg-secondary ms-1"><t t-esc="state.active_filter"/></span>
                </h6>
                <button t-if="state.active_filter !== 'Semua Data'"
                        class="btn btn-sm btn-outline-danger"
                        t-on-click="resetFilter">
                    <i class="fa fa-times me-1"></i> Reset Filter
                </button>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                                <table class="table table-striped table-hover o_list_table mb-0">
                                    <thead class="table-light" style="position: sticky; top: 0; z-index: 1; box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.1);">
                                        <tr>
                                            <th class="py-3 px-4 bg-light">Tgl Draft</th>
                                            <th class="py-3 px-4 bg-light">Tgl MOU</th>
                                            <th class="py-3 px-4 bg-light">Pelanggan</th>
                                            <th class="py-3 px-4 bg-light">Produk</th>
                                            <th class="py-3 px-4 text-center bg-light">QTY</th>
                                            <th class="py-3 px-4 text-center bg-light">DP</th>
                                            <th class="py-3 px-4 text-center bg-light">BP</th>
                                            <th class="py-3 px-4 text-center bg-light">Deadline to Delivery</th>
                                            <th class="py-3 px-4 text-center bg-light">Ontime/Overdue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="state.table_data" t-as="row" t-key="row.id" class="o_data_row">
                                            <td class="py-3 px-4"><t t-esc="row.tgl_draft"/></td>
                                            <td class="py-3 px-4 fw-bold text-primary"><t t-esc="row.tgl_mou"/></td>
                                            <td class="py-3 px-4 fw-bold"><t t-esc="row.pelanggan"/></td>
                                            <td class="py-3 px-4"><t t-esc="row.produk"/></td>
                                            <td class="py-3 px-4 text-center"><t t-esc="row.qty"/></td>
                                            <td class="py-3 px-4 text-center">
                                                <span t-attf-class="badge rounded-pill bg-{{ row.dp === '0%' ? 'danger' : 'success' }}">
                                                    <t t-esc="row.dp"/>
                                                </span>
                                            </td>
                                            <td class="py-3 px-4 text-center"><t t-esc="row.bp"/></td>
                                            <td class="py-3 px-4 text-center"><t t-esc="row.deadline_delivery"/></td>
                                            <td class="py-3 px-4 text-center">
                                                <span t-attf-class="badge rounded-pill bg-{{ row.deadline_cat === 'Overdue' ? 'danger' : (row.deadline_cat === 'Mendesak (&lt; 30 Hari)' ? 'warning text-dark' : 'success') }}">
                                                    <t t-esc="row.deadline_cat"/>
                                                </span>
                                            </td>
                                        </tr>

                                        <tr t-if="state.table_data.length === 0">
                                            <td colspan="9" class="text-center py-4 text-muted">
                                                Tidak ada data yang sesuai dengan filter.
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>