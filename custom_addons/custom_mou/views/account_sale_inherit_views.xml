<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_order_form_inherit_mou" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.mou</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="mou_id" options="{'no_create': True}"/>
                <field name="timeline_stage"/>
                <field name="is_repeat_order" widget="boolean_toggle"/>
            </xpath>

            <xpath expr="//field[@name='order_line']" position="before">
                <div class="alert alert-info o_mou_bp_info" role="alert"
                     invisible="timeline_stage != 'bp'">
                    <strong>Info Tunggakan MOU (Balance Payment)</strong>
                    <div class="d-flex gap-4 mt-1">
                        <span>Total Kontrak:
                            <field name="bp_total_kontrak" readonly="1" nolabel="1"/>
                        </span>
                        <span>Sudah Ditagih:
                            <field name="bp_total_tertagih" readonly="1" nolabel="1"/>
                        </span>
                        <span>
                            <strong>Sisa Tunggakan:
                                <field name="bp_outstanding_amount" readonly="1" nolabel="1"
                                       class="text-danger fw-bold"/>
                            </strong>
                        </span>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

    <record id="view_move_form_inherit_mou" model="ir.ui.view">
        <field name="name">account.move.form.inherit.mou</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="mou_id" invisible="move_type == 'entry'"/>
                <field name="timeline_stage" invisible="move_type == 'entry'"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_payment_form_inherit_mou" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.mou</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="mou_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>